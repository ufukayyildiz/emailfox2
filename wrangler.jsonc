{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "emailfox2",
  "main": "src/worker/index.ts",
  "compatibility_date": "2026-06-05",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client"
  },
  "vars": {
    // Required for one-click deploy. Replace example.com in the Deploy to Cloudflare setup form.
    "DOMAINS": "example.com",
    // Required for Email Routing rule creation. Keep this equal to the Worker script name chosen in deploy.
    "WORKER_SCRIPT_NAME": "emailfox"
  },
  "secrets": {
    "required": ["CLOUDFLARE_API_TOKEN"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      // Public template placeholder: Deploy to Cloudflare should replace this with a generated D1 id.
      // Installed copies must keep the generated database_id for updates.
      "database_name": "emailfox-db",
      "database_id": "517a0264-d7f3-4048-91cd-7601e27f1d93",
      "preview_database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MAIL_BUCKET",
      "bucket_name": "emailfox-mail",
      "preview_bucket_name": "emailfox-mail"
    }
  ],
  "send_email": [
    {
      "name": "EMAIL"
    }
  ]
}
